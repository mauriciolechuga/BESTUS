    {
      "configKey": "forms.becomeVendor",
      "fillWith": "{ \"path\": \"/<form-page>/\", \"submitUrlPattern\": \"**/forms.zohopublic.com/**/<ZohoFormName>/**/submit\" }",
      "verifiedAbsent": "no become-a-vendor page on live site (June 2026 onboarding)",
      "enables": "become-vendor-form.cy.js"
    }
