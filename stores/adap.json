    },
    "quoteRequest": {
      "path": "/new-request-a-quote/",
      "submitUrlPattern": "**/forms.zohopublic.com/**/ADAPRequestAQuote/**/submit"
    },
    "contact": {
      "path": "/contact-us/",
      "submitUrlPattern": "**/forms.zohopublic.com/**/ADAPContactUsNew/**/submit"
    },
    "proClub": null,
    "becomeVendor": {
      "path": "/bvl1/",
      "submitUrlPattern": "**/forms.zohopublic.com/**/ADAPcomApplyForVendor/**/submit"
    },
    "architectInquiries": null
  },
  "testEmailTemplate": "mauricio+{ts}@accessdoorsandpanels.com",
  "discovery": {
    "search": {
      "knownTerm": "fire-rated access door",
      "expectedTokens": ["fire", "rated", "access", "door"],
      "noResultsTerm": "zzzz-no-products-987654321"
    },
    "categories": [
      "/products/access-doors/",
      "/products/roof-floor-hatches/",
      "/products/popular-picks/fire-rated/"
    ],
    "mobileCategory": "/products/popular-picks/fire-rated/",
    "multiPageCategory": "/products/access-doors/",
    "sort": {
      "category": "/products/access-doors/",
      "label": "Price Low to High",
      "urlHash": "#/ps:calculated_price:asc"
    }
  },
  "pdp": {
    "popular": [
      "/18-x-18-fire-resistive-steel-access-door-milcor/",
