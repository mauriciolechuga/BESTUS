      "navLinks": "footer .footer-info-col ul li a",
      "contactInfoBox": "footer .Info-box",
      "minContactBoxes": 3,
      "phoneLinks": "footer .Info-box a[href^=\"tel:\"]",
      "minPhoneLinks": 1,
      "copyright": "footer .footer-copyright p",
      "paymentIcons": "footer .footer-payment-icons"
    }
  },
  "plp": {
    "main": "/products/access-doors/",
