{
  "_notes": "Configured from the live site (June 2026). Quirks: /products/ root 301s to an external subdomain, so plp.main is the Access Doors category; no Pro Club; quote form lives at /new-request-a-quote/; theme differs from BESTUS (footer-v2, .Info-box contact column, plain .breadcrumbs, no sidebar .categories-left, no related-products carousel, product form in #crmWebToEntityForm).",
  "storeCode": "ADAP",
  "baseUrl": "https://www.accessdoorsandpanels.com",
  "homePath": "/",
  "visitQuery": null,
  "branding": {
    "copyrightText": "AccessDoorsAndPanels",
