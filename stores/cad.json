{
  "_notes": "Configured June 2026. Standard BigCommerce theme (ul.productGrid, h1.page-heading, .breadcrumbs). No SearchSpring — native BC sort (?sort=priceasc) and search (search.php). Native BC search always returns results — no zero-result state. Products have prices (not quote-only). Footer: plain <footer> (no .tcsFooter), three sibling sections (footer-top / footer-bottom / footer-copyright), h3 headings in .box divs. Mobile nav is #menu (native BC toggle container). No sidebar on category pages. Subcategory boxes use li.subcategory_box / a.nameTitle / a.subcategory_image. PDP: #zoho_product_form for product info form, section[data-image-gallery] img for gallery, .productView-description for description. No related carousel, no Yotpo reviews, no SS recently-viewed.",
  "storeCode": "CAD",
  "baseUrl": "https://www.californiaaccessdoors.com",
  "homePath": "/",
  "visitQuery": null,
  "branding": {
    "copyrightText": "California Access Doors",
    "footerLocationText": "San Francisco",
    "warehousesLink": { "href": "/warehouses/", "text": "WAREHOUSES" },
    "imageHosts": ["californiaaccessdoors.com", "bigcommerce.com"],
    "partnerLinks": null,
    "mobileNavSelector": "#menu",
    "footer": {
      "rootSelector": "footer",
      "sections": ["footer .footer-top", "footer .footer-bottom", "footer .footer-copyright"],
      "headingSelector": "footer .box h3",
      "headings": ["WHAT'S IN STORE", "SECURE SHOPPING", "MY ACCOUNT", "CONTACT INFO"],
      "navLinks": "footer .box ul li a",
      "contactInfoBox": "footer .box:last-child",
      "minContactBoxes": 1,
      "phoneLinks": "footer a[href^=\"tel:\"]",
      "minPhoneLinks": 2,
      "copyright": "footer .footer-copyright p",
      "paymentIcons": "footer .footer-payment-icons"
    }
  },
  "plp": {
    "main": "/fire-rated-access-doors/",
    "mainHeading": "Fire-Rated",
    "breadcrumbLabel": "Fire-Rated",
    "subcategory": "/for-drywall-installation/",
    "selectors": {
      "breadcrumbs": ".breadcrumbs",
      "breadcrumbHome": null,
      "sidebar": null,
      "bestSellers": null,
      "subcategoryBox": "li.subcategory_box",
      "subcategoryLink": "a.subcategory_image",
      "cardPrice": ".price--withoutTax",
      "pagination": {
        "container": ".pagination-list",
        "active": ".pagination-item--current",
        "links": "li.pagination-item a",
        "next": ".pagination-item--next a",
        "pageTwoToken": "page=2"
      }
    }
  },
  "products": {
    "default": "/36-x-48-fire-rated-insulated-access-door-with-flange-for-drywall/",
