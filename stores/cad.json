    "quoteRequest": {
      "path": "/quote-request/",
      "submitUrlPattern": "**/forms.zohopublic.com/**/CADRequestAQuote/**/submit",
      "optionalFields": ["Name_First"]
    },
    "contact": {
      "path": "/contact-us/",
      "submitUrlPattern": "**/forms.zohopublic.com/**/CADContactUsNew/**/submit"
    },
    "proClub": null,
    "becomeVendor": null,
    "architectInquiries": {
      "path": "/architects/",
      "submitUrlPattern": "**/forms.zohopublic.com/**/CADArchitects/**/submit"
    }
  },
  "testEmailTemplate": "mauricio+{ts}@californiaaccessdoors.com",
  "discovery": {
    "search": {
      "knownTerm": "fire rated access door",
      "expectedTokens": ["fire", "rated", "access", "door"],
      "noResultsTerm": null,
      "pdpUrlClean": false
    },
    "categories": [
      "/fire-rated-access-doors/",
      "/ceiling-attic-access-doors/",
      "/drywall-access-doors/"
    ],
    "mobileCategory": "/fire-rated-access-doors/",
    "multiPageCategory": "/fire-rated-access-doors/",
